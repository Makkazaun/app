generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./portal.db"
}

model User {
  id                   Int      @id @default(autoincrement())
  email                String   @unique
  password             String
  name                 String?
  kKunde               Int?     @unique
  notificationsEnabled Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}